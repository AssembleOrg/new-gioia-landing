---
import { whatsappLink, site } from "../data/site";
---

<section class="cta" data-cta>
  <div class="cta__pattern" aria-hidden="true"></div>
  <div class="cta__decor cta__decor--1" aria-hidden="true"></div>
  <div class="cta__decor cta__decor--2" aria-hidden="true"></div>

  <div class="container cta__inner">
    <div class="cta__text">
      <span class="eyebrow eyebrow--light">Cotizar</span>
      <h2 class="cta__title">¿Listo para tu próxima mudanza?</h2>
      <p class="cta__lead">
        Contanos qué necesitás trasladar y desde dónde a dónde. Te respondemos rápido con un
        presupuesto claro, sin letra chica.
      </p>
    </div>

    <div class="cta__actions">
      <a class="btn btn-whatsapp cta__btn" href={whatsappLink()} target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26L2.5 19.51l3.654-1.317zm9.612-7.408c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.149-.174.198-.298.298-.496.099-.198.05-.372-.025-.521-.075-.149-.669-1.611-.916-2.207-.241-.579-.486-.5-.668-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"></path>
        </svg>
        Escribinos por WhatsApp
      </a>
      <a class="btn cta__btn cta__btn--outline" href={`tel:${site.phoneIntl}`}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.33 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Llamar al {site.phoneDisplay}
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    background: linear-gradient(135deg, #4a1018 0%, var(--bordo-dark) 40%, var(--bordo) 100%);
    color: var(--white);
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding-block: clamp(80px, 12vw, 130px);
  }

  .cta__pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 28px 28px;
    mask-image: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0) 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0) 70%);
    pointer-events: none;
    z-index: 0;
  }

  .cta__decor {
    position: absolute;
    border-radius: 999px;
    pointer-events: none;
    z-index: 0;
    filter: blur(40px);
  }

  .cta__decor--1 {
    top: -100px;
    right: -80px;
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.14) 0%, transparent 70%);
  }

  .cta__decor--2 {
    bottom: -120px;
    left: -100px;
    width: 320px;
    height: 320px;
    background: radial-gradient(circle, rgba(155, 42, 58, 0.35) 0%, transparent 70%);
  }

  .cta__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    align-items: center;
    gap: clamp(28px, 5vw, 64px);
  }

  .cta__title {
    color: var(--white);
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    margin-bottom: 16px;
  }

  .cta__lead {
    color: rgba(255, 255, 255, 0.85);
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    line-height: 1.55;
    max-width: 50ch;
    margin: 0;
  }

  .cta__actions {
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: stretch;
  }

  .cta__btn {
    padding: 16px 26px;
    font-size: 1rem;
    justify-content: center;
  }

  .cta__btn--outline {
    background: transparent;
    color: var(--white);
    border: 1.5px solid rgba(255, 255, 255, 0.45);
  }

  .cta__btn--outline:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--white);
  }

  @media (max-width: 880px) {
    .cta__inner {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .cta__actions {
      gap: 10px;
    }
  }
</style>
