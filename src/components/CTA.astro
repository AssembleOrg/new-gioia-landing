---
import { whatsappLink, site } from "../data/site";
---

<section class="cta section">
  <div class="container cta__inner">
    <div class="cta__text">
      <span class="eyebrow">Cotizar</span>
      <h2>¿Listo para tu próxima mudanza?</h2>
      <p>
        Contanos qué necesitás trasladar y desde dónde a dónde. Te respondemos rápido con un
        presupuesto claro, sin letra chica.
      </p>
    </div>

    <div class="cta__actions">
      <a class="btn btn-whatsapp btn-lg" href={whatsappLink()} target="_blank" rel="noopener">
        Escribinos por WhatsApp
      </a>
      <a class="btn btn-dark btn-lg" href={`tel:${site.phoneIntl}`}>
        Llamar al {site.phoneDisplay}
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    background:
      linear-gradient(135deg, var(--bordo-dark) 0%, var(--bordo) 60%, var(--bordo-light) 100%);
    color: var(--white);
    position: relative;
    overflow: hidden;
  }

  .cta::before {
    content: "";
    position: absolute;
    inset: -60px;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.08) 0, transparent 40%),
      radial-gradient(circle at 80% 70%, rgba(0, 0, 0, 0.18) 0, transparent 40%);
    pointer-events: none;
  }

  .cta__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 40px;
    position: relative;
  }

  .cta__text h2 {
    margin-bottom: 12px;
  }

  .cta__text p {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.05rem;
    max-width: 50ch;
    margin: 0;
  }

  .cta__actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .btn-lg {
    padding: 16px 30px;
    font-size: 1rem;
  }

  @media (max-width: 740px) {
    .cta__inner {
      grid-template-columns: 1fr;
    }
    .cta__actions {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }
</style>
