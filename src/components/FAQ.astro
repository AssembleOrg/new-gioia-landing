---
const faqs = [
  {
    q: "¿Cuánto tarda en llegar la cotización?",
    a: "Si nos escribís por WhatsApp en horario laboral, te respondemos en menos de una hora con un primer estimativo. Para una cotización cerrada coordinamos visita o videollamada el mismo día o al siguiente.",
  },
  {
    q: "¿Cobran por la visita o asesoría?",
    a: "No. La asesoría y el presupuesto son sin cargo y sin compromiso. Recién facturamos cuando confirmás el servicio.",
  },
  {
    q: "¿Hacen mudanzas fuera del AMBA?",
    a: "Sí. Realizamos traslados a todas las provincias del país. Coordinamos fecha y hora según disponibilidad y kilometraje.",
  },
  {
    q: "¿Embalan ellos o tengo que dejar todo en cajas?",
    a: "Las dos opciones son posibles. Podemos llevar materiales y embalar lo delicado (vajilla, electrónicos, cuadros, ropa) o trabajar con cajas que ya tengas armadas.",
  },
  {
    q: "¿Qué pasa si necesito guardar las cosas un tiempo?",
    a: "Tenemos servicio de guardamuebles propio. Tus pertenencias quedan en boxes individuales en un depósito vigilado, el tiempo que necesites.",
  },
  {
    q: "¿Trabajan los fines de semana?",
    a: "Sí, atendemos sábados y, según disponibilidad, también domingos. Para mudanzas comerciales coordinamos fuera del horario operativo de tu empresa.",
  },
];
---

<section id="faq" class="faq section">
  <div class="container">
    <header class="faq__head">
      <span class="eyebrow">Preguntas frecuentes</span>
      <h2>Lo que más nos preguntan antes de contratar.</h2>
    </header>

    <div class="faq__list">
      {
        faqs.map((f, i) => (
          <details class="faq__item" open={i === 0}>
            <summary>
              <span>{f.q}</span>
              <span class="faq__plus" aria-hidden="true" />
            </summary>
            <p>{f.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "¿Cuánto tarda en llegar la cotización?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Si nos escribís por WhatsApp en horario laboral, te respondemos en menos de una hora con un primer estimativo. Para una cotización cerrada coordinamos visita o videollamada el mismo día o al siguiente.",
        },
      },
      {
        "@type": "Question",
        name: "¿Cobran por la visita o asesoría?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "No. La asesoría y el presupuesto son sin cargo y sin compromiso. Recién facturamos cuando confirmás el servicio.",
        },
      },
      {
        "@type": "Question",
        name: "¿Hacen mudanzas fuera del AMBA?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Sí. Realizamos traslados a todas las provincias del país. Coordinamos fecha y hora según disponibilidad y kilometraje.",
        },
      },
      {
        "@type": "Question",
        name: "¿Embalan ellos o tengo que dejar todo en cajas?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Las dos opciones son posibles. Podemos llevar materiales y embalar lo delicado o trabajar con cajas que ya tengas armadas.",
        },
      },
      {
        "@type": "Question",
        name: "¿Qué pasa si necesito guardar las cosas un tiempo?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Tenemos servicio de guardamuebles propio. Tus pertenencias quedan en boxes individuales en un depósito vigilado.",
        },
      },
      {
        "@type": "Question",
        name: "¿Trabajan los fines de semana?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Sí, atendemos sábados y, según disponibilidad, también domingos. Para mudanzas comerciales coordinamos fuera del horario operativo de tu empresa.",
        },
      },
    ],
  })}
/>

<style>
  .faq {
    background: var(--gris-100);
  }

  .faq__head {
    max-width: 640px;
    margin-bottom: 40px;
  }

  .faq__list {
    display: grid;
    gap: 12px;
    max-width: 820px;
  }

  .faq__item {
    background: var(--white);
    border: 1px solid var(--gris-200);
    border-radius: var(--radius-md);
    padding: 18px 22px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .faq__item[open] {
    border-color: var(--bordo);
    box-shadow: var(--shadow-sm);
  }

  .faq__item summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    font-weight: 600;
    color: var(--ink);
    font-size: 1.02rem;
  }

  .faq__item summary::-webkit-details-marker {
    display: none;
  }

  .faq__plus {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    position: relative;
  }

  .faq__plus::before,
  .faq__plus::after {
    content: "";
    position: absolute;
    background: var(--bordo);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .faq__plus::before {
    width: 14px;
    height: 2px;
  }

  .faq__plus::after {
    width: 2px;
    height: 14px;
    transition: transform 0.2s ease;
  }

  .faq__item[open] .faq__plus::after {
    transform: translate(-50%, -50%) scaleY(0);
  }

  .faq__item p {
    margin: 14px 0 0;
    color: var(--gris-700);
    font-size: 0.96rem;
    line-height: 1.6;
  }
</style>
