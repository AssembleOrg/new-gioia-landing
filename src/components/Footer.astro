---
import { site, whatsappLink } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <img class="footer__mark" src={site.logoPath} alt={`Logo ${site.shortName}`} width="256" height="31" loading="lazy" decoding="async" />
      <strong>Transporte Gioia e Hijos SRL</strong>
      <p class="footer__tagline">
        Mudanzas y guardamuebles desde Lanús para todo el país.
      </p>
    </div>

    <div class="footer__col">
      <h3>Servicios</h3>
      <ul>
        <li><a href="/mudanzas-lanus">Mudanzas en Lanús</a></li>
        <li><a href="/mudanzas-capital-federal">Mudanzas a CABA</a></li>
        <li><a href="/#servicios">Mudanzas entre provincias</a></li>
        <li><a href="/guardamuebles-lanus">Guardamuebles</a></li>
      </ul>
    </div>

    <div class="footer__col footer__col--contact">
      <h3>Contacto</h3>
      <ul class="footer__contact">
        <li>
          <a href={whatsappLink()} target="_blank" rel="noopener" class="footer__contact-link">
            <span class="footer__contact-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26L2.5 19.51l3.654-1.317zm9.612-7.408c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.149-.174.198-.298.298-.496.099-.198.05-.372-.025-.521-.075-.149-.669-1.611-.916-2.207-.241-.579-.486-.5-.668-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"/>
              </svg>
            </span>
            <span class="footer__contact-text">
              <span class="footer__contact-label">WhatsApp</span>
              <strong>{site.phoneDisplay}</strong>
            </span>
          </a>
        </li>
        <li>
          <a href={`tel:${site.phoneIntl}`} class="footer__contact-link">
            <span class="footer__contact-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.33 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="footer__contact-text">
              <span class="footer__contact-label">Teléfono</span>
              <strong>{site.phoneDisplay}</strong>
            </span>
          </a>
        </li>
        <li>
          <a href={`mailto:${site.email}`} class="footer__contact-link">
            <span class="footer__contact-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="5" width="18" height="14" rx="2" />
                <path d="m3 7 9 6 9-6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="footer__contact-text">
              <span class="footer__contact-label">Email</span>
              <strong>{site.email}</strong>
            </span>
          </a>
        </li>
        <li>
          <a href={site.social.instagram} target="_blank" rel="noopener" class="footer__contact-link">
            <span class="footer__contact-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
              </svg>
            </span>
            <span class="footer__contact-text">
              <span class="footer__contact-label">Instagram</span>
              <strong>{site.social.instagramHandle}</strong>
            </span>
          </a>
        </li>
      </ul>
    </div>

    <div class="footer__col">
      <h3>Base operativa</h3>
      <address>
        {site.address.street}<br />
        {site.address.city}, {site.address.region}<br />
        {site.address.country}
      </address>
      <p class="footer__hours">{site.hours}</p>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <span>© {year} Transporte Gioia e Hijos SRL · Todos los derechos reservados.</span>
      <a
        class="footer__creator"
        href="https://api.whatsapp.com/send/?phone=5491138207230&text&type=phone_number&app_absent=0"
        target="_blank"
        rel="noopener"
      >
        <span class="footer__creator-label">Creado por</span>
        <span class="footer__creator-badge">Pistech</span>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink-deep);
    color: var(--gris-200);
    padding-top: 72px;
    padding-bottom: env(safe-area-inset-bottom);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .footer::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(155, 42, 58, 0.6), transparent);
    z-index: 1;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1.5fr 1fr;
    gap: 40px;
    padding-bottom: 48px;
    position: relative;
    z-index: 1;
  }

  .footer__brand strong {
    display: block;
    color: var(--white);
    font-size: 1.1rem;
    margin: 14px 0 8px;
  }

  .footer__mark {
    width: auto;
    height: 38px;
    max-width: min(60vw, 220px);
    border-radius: 8px;
    object-fit: contain;
    object-position: left center;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.12);
  }

  .footer__tagline {
    color: var(--gris-500);
    font-size: 0.92rem;
    margin: 0;
  }

  .footer__col h3 {
    font-family: var(--font-body);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.78rem;
    color: var(--white);
    margin-bottom: 16px;
  }

  .footer__col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }

  .footer__col a {
    color: var(--gris-200);
    font-size: 0.92rem;
    transition: color 0.15s ease;
    display: inline-block;
    padding: 4px 0;
    min-height: 32px;
  }

  .footer__col a:hover {
    color: var(--white);
  }

  /* Contact column */
  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .footer__contact-link {
    display: grid !important;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 14px;
    padding: 6px 0 !important;
    color: var(--gris-200);
    min-height: 44px;
    transition: transform 0.25s var(--ease-out-expo);
  }

  .footer__contact-link:hover {
    transform: translateX(3px);
  }

  .footer__contact-icon {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    background: var(--bordo);
    color: var(--white);
    display: grid;
    place-items: center;
    flex-shrink: 0;
    box-shadow: 0 6px 14px rgba(122, 31, 44, 0.32);
    transition: background 0.2s ease, transform 0.25s var(--ease-out-expo);
  }

  .footer__contact-link:hover .footer__contact-icon {
    background: var(--bordo-light);
    transform: scale(1.06);
  }

  .footer__contact-icon svg {
    width: 18px;
    height: 18px;
    display: block;
  }

  .footer__contact-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    min-width: 0;
  }

  .footer__contact-label {
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--gris-500);
    margin-bottom: 3px;
  }

  .footer__contact-text strong {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.05rem;
    color: var(--white);
    letter-spacing: 0.03em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .footer__contact-link:hover .footer__contact-text strong {
    color: var(--bordo-accent, var(--white));
  }

  @media (prefers-reduced-motion: reduce) {
    .footer__contact-link,
    .footer__contact-icon {
      transition: none;
    }
  }

  address {
    font-style: normal;
    font-size: 0.92rem;
    color: var(--gris-200);
    margin-bottom: 12px;
    line-height: 1.55;
  }

  .footer__hours {
    font-size: 0.86rem;
    color: var(--gris-300);
    margin: 0;
  }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-block: 22px;
    position: relative;
    z-index: 1;
  }

  .footer__bottom-inner {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    font-size: 0.82rem;
    color: var(--gris-300);
  }

  .footer__creator {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    transition: transform 0.15s ease;
  }

  .footer__creator-label {
    color: var(--gris-300);
    font-size: 1.05rem;
    font-weight: 500;
    line-height: 1;
  }

  .footer__creator-badge {
    color: #e9d34f;
    border: 2px solid var(--bordo);
    border-radius: 3px;
    padding: 3px 8px;
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.01em;
    background: rgba(122, 31, 44, 0.1);
  }

  .footer__creator:hover {
    transform: translateY(-1px);
  }

  .footer__creator:hover .footer__creator-badge {
    color: #f8e174;
    border-color: #9b2a3a;
  }

  @media (max-width: 880px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
    }

    .footer__col--contact {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 520px) {
    .footer__creator-label {
      font-size: 0.95rem;
    }

    .footer__creator-badge {
      font-size: 1rem;
    }
    .footer__mark {
      height: 32px;
      max-width: min(74vw, 180px);
    }
    .footer__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
