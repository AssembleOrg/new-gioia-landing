---
import { site, whatsappLink } from "../data/site";

const navLinks = [
  { href: "/#servicios", label: "Servicios" },
  { href: "/#proceso", label: "Cómo trabajamos" },
  { href: "/guardamuebles-lanus", label: "Guardamuebles" },
  { href: "/#cobertura", label: "Cobertura" },
  { href: "/#faq", label: "Preguntas" },
];
---

<header class="header" data-header>
  <div class="container header__inner">
    <a href="/" class="brand" aria-label={site.name}>
      <img class="brand__mark" src={site.logoPath} alt={`Logo ${site.shortName}`} width="256" height="31" loading="eager" decoding="async" fetchpriority="high" />
    </a>

    <nav class="nav" aria-label="Navegación principal">
      {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <a class="btn btn-primary header__cta" href={whatsappLink()} target="_blank" rel="noopener">
      Cotizar por WhatsApp
    </a>

    <button
      class="hamburger"
      type="button"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mobile-drawer"
      data-hamburger
    >
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
    </button>
  </div>

  <div class="drawer" id="mobile-drawer" data-drawer aria-hidden="true">
    <div class="drawer__backdrop" data-drawer-backdrop></div>
    <div class="drawer__panel" role="dialog" aria-modal="true" aria-label="Menú de navegación">
      <nav class="drawer__nav" aria-label="Navegación móvil">
        {navLinks.map((l, i) => (
          <a href={l.href} class="drawer__link" style={`--i:${i}`} data-drawer-link>{l.label}</a>
        ))}
      </nav>
      <div class="drawer__footer">
        <a class="btn btn-whatsapp drawer__cta" href={whatsappLink()} target="_blank" rel="noopener" data-drawer-link>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26L2.5 19.51l3.654-1.317zm9.612-7.408c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.149-.174.198-.298.298-.496.099-.198.05-.372-.025-.521-.075-.149-.669-1.611-.916-2.207-.241-.579-.486-.5-.668-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"></path>
          </svg>
          Cotizar por WhatsApp
        </a>
        <a class="drawer__phone" href={`tel:${site.phoneIntl}`}>
          <span>Llamar</span>
          <strong>{site.phoneDisplay}</strong>
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    color: var(--white);
    border-bottom: 1px solid transparent;
    transition: background 0.3s ease, backdrop-filter 0.3s ease, border-color 0.3s ease;
  }

  .header.is-scrolled {
    background: rgba(10, 10, 10, 0.88);
    backdrop-filter: saturate(160%) blur(14px);
    -webkit-backdrop-filter: saturate(160%) blur(14px);
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: 24px;
    height: 72px;
  }

  .brand {
    display: flex;
    align-items: center;
    color: var(--white);
    flex-shrink: 0;
  }

  .brand__mark {
    width: auto;
    height: 34px;
    max-width: min(44vw, 210px);
    object-fit: contain;
    object-position: left center;
  }

  .nav {
    display: flex;
    gap: 28px;
    margin-left: auto;
    margin-right: 8px;
  }

  .nav a {
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--white);
    transition: color 0.15s ease;
    position: relative;
    padding: 6px 0;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.35);
  }

  .nav a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--white);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s var(--ease-out-expo);
  }

  .nav a:hover {
    color: var(--white);
  }

  .nav a:hover::after {
    transform: scaleX(1);
  }

  .header__cta {
    padding: 10px 18px;
    font-size: 0.88rem;
  }

  /* Hamburger button */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 10px;
    margin-left: auto;
    background: transparent;
    border: 0;
    cursor: pointer;
    color: var(--white);
    border-radius: 8px;
  }

  .hamburger__bar {
    display: block;
    width: 22px;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transform-origin: center;
    transition: transform 0.3s var(--ease-out-expo), opacity 0.2s ease;
  }

  .hamburger[aria-expanded="true"] .hamburger__bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger[aria-expanded="true"] .hamburger__bar:nth-child(2) {
    opacity: 0;
  }
  .hamburger[aria-expanded="true"] .hamburger__bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Drawer */
  .drawer {
    position: fixed;
    inset: 0;
    z-index: 49;
    pointer-events: none;
    visibility: hidden;
  }

  .drawer.is-open {
    pointer-events: auto;
    visibility: visible;
  }

  .drawer__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 10, 0.6);
    opacity: 0;
    transition: opacity 0.35s var(--ease-out-expo);
  }

  .drawer.is-open .drawer__backdrop {
    opacity: 1;
  }

  .drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    height: 100dvh;
    width: min(420px, 92vw);
    background: rgba(10, 10, 10, 0.96);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-left: 1px solid rgba(255, 255, 255, 0.08);
    padding: 96px 32px 32px;
    padding-bottom: max(32px, env(safe-area-inset-bottom));
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.4s var(--ease-out-expo);
    overflow-y: auto;
  }

  .drawer.is-open .drawer__panel {
    transform: translateX(0);
  }

  .drawer__nav {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1;
  }

  .drawer__link {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 6vw, 2.4rem);
    line-height: 1;
    color: var(--white);
    padding: 14px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    letter-spacing: 0.02em;
    opacity: 0;
    transform: translateX(20px);
    transition: opacity 0.4s var(--ease-out-expo), transform 0.4s var(--ease-out-expo), color 0.2s ease;
    transition-delay: calc(var(--i, 0) * 50ms + 150ms);
    min-height: 44px;
    display: flex;
    align-items: center;
  }

  .drawer.is-open .drawer__link {
    opacity: 1;
    transform: translateX(0);
  }

  .drawer__link:hover,
  .drawer__link:focus-visible {
    color: var(--gris-300);
  }

  .drawer__footer {
    padding-top: 32px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s var(--ease-out-expo) 450ms, transform 0.4s var(--ease-out-expo) 450ms;
  }

  .drawer.is-open .drawer__footer {
    opacity: 1;
    transform: translateY(0);
  }

  .drawer__cta {
    width: 100%;
  }

  .drawer__phone {
    display: flex;
    flex-direction: column;
    gap: 2px;
    color: var(--white);
    padding: 8px 0;
    min-height: 44px;
    justify-content: center;
  }

  .drawer__phone span {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--gris-500);
  }

  .drawer__phone strong {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--white);
    letter-spacing: 0.04em;
  }

  @media (max-width: 920px) {
    .nav,
    .header__cta {
      display: none;
    }
    .hamburger {
      display: flex;
    }
  }

  @media (max-width: 520px) {
    .brand__mark {
      height: 28px;
      max-width: min(52vw, 155px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .drawer__backdrop,
    .drawer__panel,
    .drawer__link,
    .drawer__footer,
    .hamburger__bar {
      transition: none;
    }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>('[data-header]');
  const hamburger = document.querySelector<HTMLButtonElement>('[data-hamburger]');
  const drawer = document.querySelector<HTMLElement>('[data-drawer]');
  const backdrop = document.querySelector<HTMLElement>('[data-drawer-backdrop]');
  const drawerLinks = document.querySelectorAll<HTMLAnchorElement>('[data-drawer-link]');

  let isOpen = false;
  let lastFocused: HTMLElement | null = null;

  function openDrawer() {
    if (!drawer || !hamburger) return;
    isOpen = true;
    lastFocused = document.activeElement as HTMLElement;
    drawer.classList.add('is-open');
    drawer.setAttribute('aria-hidden', 'false');
    hamburger.setAttribute('aria-expanded', 'true');
    hamburger.setAttribute('aria-label', 'Cerrar menú de navegación');
    document.body.classList.add('is-locked');
    const firstLink = drawer.querySelector<HTMLAnchorElement>('.drawer__link');
    setTimeout(() => firstLink?.focus(), 200);
  }

  function closeDrawer() {
    if (!drawer || !hamburger) return;
    isOpen = false;
    drawer.classList.remove('is-open');
    drawer.setAttribute('aria-hidden', 'true');
    hamburger.setAttribute('aria-expanded', 'false');
    hamburger.setAttribute('aria-label', 'Abrir menú de navegación');
    document.body.classList.remove('is-locked');
    lastFocused?.focus();
  }

  hamburger?.addEventListener('click', () => (isOpen ? closeDrawer() : openDrawer()));
  backdrop?.addEventListener('click', closeDrawer);
  drawerLinks.forEach((link) => link.addEventListener('click', closeDrawer));

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closeDrawer();
  });

  // Header background on scroll
  let scrolled = false;
  function onScroll() {
    const next = window.scrollY > 88;
    if (next !== scrolled) {
      scrolled = next;
      header?.classList.toggle('is-scrolled', scrolled);
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
