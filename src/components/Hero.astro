---
import { Picture } from "astro:assets";
import { whatsappLink, site } from "../data/site";
import camionFrontal from "../assets/images/camion-frontal.png";
---

<section class="hero">
  <div class="hero__bg" aria-hidden="true"></div>

  <div class="container hero__inner">
    <div class="hero__content">
      <span class="hero__eyebrow">Transporte Gioia e Hijos · Lanús</span>
      <h1 class="hero__title">
        Mudanzas <span class="hero__title--accent">rápidas</span> y guardamuebles seguros.
      </h1>
      <p class="hero__lead">
        Más de una década moviendo familias y empresas por Buenos Aires y todas las provincias.
        Embalaje, traslado y depósito con el cuidado que tus cosas se merecen.
      </p>

      <ul class="hero__pillars">
        <li><span class="check">✓</span> Profesionalismo</li>
        <li><span class="check">✓</span> Puntualidad</li>
        <li><span class="check">✓</span> Seguridad</li>
        <li><span class="check">✓</span> Asesoría sin cargo</li>
      </ul>

      <div class="hero__ctas">
        <a class="btn btn-whatsapp" href={whatsappLink()} target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26L2.5 19.51l3.654-1.317zm9.612-7.408c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.149-.174.198-.298.298-.496.099-.198.05-.372-.025-.521-.075-.149-.669-1.611-.916-2.207-.241-.579-.486-.5-.668-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"
            ></path>
          </svg>
          Cotizar por WhatsApp
        </a>
        <a class="btn btn-ghost" href="#servicios">Ver servicios</a>
      </div>

      <div class="hero__contact">
        <a href={`tel:${site.phoneIntl}`} class="hero__phone">
          <span class="hero__phone-label">Teléfono</span>
          <span class="hero__phone-number">{site.phoneDisplay}</span>
        </a>
        <span class="hero__sep" aria-hidden="true"></span>
        <span class="hero__addr">{site.address.street}, {site.address.city}</span>
      </div>
    </div>

    <div class="hero__visual">
      <div class="hero__img-wrap">
        <Picture
          src={camionFrontal}
          alt="Camión de mudanzas Transporte Gioia e Hijos"
          widths={[480, 720, 960, 1200]}
          sizes="(max-width: 880px) 92vw, 480px"
          formats={["avif", "webp"]}
          quality={75}
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
      <div class="hero__badge">
        <strong>+500 Mudanzas</strong>
        <span>realizadas con éxito</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    color: var(--white);
    overflow: hidden;
    isolation: isolate;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(900px 500px at 85% 10%, rgba(155, 42, 58, 0.55) 0%, rgba(155, 42, 58, 0) 60%),
      radial-gradient(700px 600px at 0% 100%, rgba(122, 31, 44, 0.45) 0%, rgba(0, 0, 0, 0) 60%),
      linear-gradient(180deg, #1a1a1a 0%, #0f0f0f 100%);
    z-index: -1;
  }

  .hero__bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0) 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0) 70%);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
    padding-block: clamp(70px, 10vw, 130px);
  }

  .hero__eyebrow {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #f0c2c8;
    background: rgba(155, 42, 58, 0.22);
    padding: 6px 14px;
    border-radius: 999px;
    margin-bottom: 22px;
    border: 1px solid rgba(155, 42, 58, 0.45);
  }

  .hero__title {
    font-size: clamp(2.6rem, 6.4vw, 5rem);
    line-height: 0.95;
    margin-bottom: 22px;
  }

  .hero__title--accent {
    color: var(--bordo-light);
  }

  .hero__lead {
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    color: var(--gris-300);
    max-width: 56ch;
    margin-bottom: 28px;
  }

  .hero__pillars {
    list-style: none;
    margin: 0 0 32px;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, max-content));
    gap: 10px 28px;
    color: var(--gris-200);
    font-weight: 500;
  }

  .hero__pillars li {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .check {
    display: inline-grid;
    place-items: center;
    width: 22px;
    height: 22px;
    background: var(--bordo);
    color: var(--white);
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-bottom: 36px;
  }

  .hero__contact {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 18px;
    color: var(--gris-300);
    font-size: 0.92rem;
  }

  .hero__phone {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .hero__phone-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--gris-500);
  }

  .hero__phone-number {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--white);
    letter-spacing: 0.04em;
  }

  .hero__sep {
    width: 1px;
    height: 28px;
    background: rgba(255, 255, 255, 0.18);
  }

  .hero__visual {
    position: relative;
  }

  .hero__img-wrap {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    background: transparent;
    aspect-ratio: 1080 / 1350;
  }

  .hero__img-wrap :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero__img-wrap :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__badge {
    position: absolute;
    bottom: -18px;
    left: -18px;
    background: var(--white);
    color: var(--ink);
    padding: 16px 22px;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .hero__badge strong {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--bordo);
    letter-spacing: 0.04em;
  }

  .hero__badge span {
    font-size: 0.82rem;
    color: var(--gris-700);
  }

  @media (max-width: 880px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }
    .hero__visual {
      order: -1;
      max-width: 460px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
    }
    .hero__img-wrap {
      width: 100%;
    }
    .hero__badge {
      position: static;
    }
  }

  @media (max-width: 520px) {
    .hero__badge {
      padding: 12px 18px;
    }
    .hero__badge strong {
      font-size: 1.4rem;
    }
  }
</style>
