---
import { Image } from "astro:assets";
import { whatsappLink } from "../data/site";
import guardamueblesBlanco from "../assets/images/guardamuebles-blanco.png";
---

<section id="guardamuebles" class="storage section">
  <div class="container storage__inner">
    <div class="storage__visual">
      <Image
        src={guardamueblesBlanco}
        alt="Boxes individuales del servicio de guardamuebles"
        widths={[480, 720, 960]}
        sizes="(max-width: 880px) 92vw, 480px"
        format="webp"
        quality={80}
        loading="lazy"
        decoding="async"
      />
      <div class="storage__tag">Servicio de guardamuebles</div>
    </div>

    <div class="storage__content">
      <span class="eyebrow">Guardamuebles</span>
      <h2>¿Tu mudanza no coincide con los tiempos?</h2>
      <p class="storage__lead">
        Guardamos tus muebles, cajas y pertenencias el tiempo que necesites en un depósito seguro,
        seco y vigilado. Ideal para mudanzas escalonadas, refacciones o estadías temporales.
      </p>

      <ul class="storage__features">
        <li><span class="dot"></span> Boxes individuales con acceso coordinado</li>
        <li><span class="dot"></span> Depósito vigilado las 24 horas</li>
        <li><span class="dot"></span> Inventario detallado al ingreso</li>
        <li><span class="dot"></span> Embalaje y traslado al depósito incluidos</li>
      </ul>

      <a class="btn btn-primary" href={whatsappLink("Hola, me interesa el servicio de guardamuebles. ¿Me pasan info?")} target="_blank" rel="noopener">
        Consultar disponibilidad
      </a>
    </div>
  </div>
</section>

<style>
  .storage {
    background: linear-gradient(180deg, var(--gris-100) 0%, var(--white) 100%);
  }

  .storage__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }

  .storage__visual {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .storage__visual :global(picture) {
    display: block;
    width: 100%;
  }

  .storage__visual :global(img) {
    width: 100%;
    height: auto;
  }

  .storage__tag {
    position: absolute;
    bottom: 18px;
    left: 18px;
    background: var(--bordo);
    color: var(--white);
    padding: 10px 18px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
  }

  .storage__content h2 {
    color: var(--ink);
  }

  .storage__lead {
    color: var(--gris-700);
    font-size: 1.05rem;
    margin-bottom: 24px;
  }

  .storage__features {
    list-style: none;
    margin: 0 0 32px;
    padding: 0;
    display: grid;
    gap: 12px;
    color: var(--ink);
    font-weight: 500;
  }

  .storage__features li {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--bordo);
    flex-shrink: 0;
  }

  @media (max-width: 880px) {
    .storage__inner {
      grid-template-columns: 1fr;
    }
    .storage__visual {
      max-width: 460px;
      margin: 0 auto;
    }
  }
</style>
