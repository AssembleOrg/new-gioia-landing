---
import { whatsappLink } from "../data/site";
---

<a
  class="wa-float"
  href={whatsappLink()}
  target="_blank"
  rel="noopener"
  aria-label="Cotizar por WhatsApp — Transporte Gioia"
>
  <svg
    class="wa-float__icon"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 32 32"
    fill="currentColor"
    aria-hidden="true"
  >
    <path
      d="M16.003 3C8.835 3 3 8.835 3 16.003c0 2.31.6 4.563 1.74 6.55L3 29l6.62-1.733a12.94 12.94 0 0 0 6.383 1.62h.005C23.176 28.887 29 23.052 29 15.884 29 12.413 27.65 9.144 25.198 6.69A12.91 12.91 0 0 0 16.003 3Zm0 23.683h-.004a10.78 10.78 0 0 1-5.49-1.503l-.394-.234-3.927 1.028 1.05-3.83-.257-.4a10.74 10.74 0 0 1-1.65-5.74c.002-5.94 4.836-10.774 10.776-10.774 2.879 0 5.583 1.122 7.617 3.158a10.7 10.7 0 0 1 3.157 7.62c-.002 5.94-4.835 10.774-10.776 10.774Zm5.913-8.07c-.324-.162-1.917-.946-2.214-1.054-.297-.108-.513-.162-.73.162-.215.324-.836 1.054-1.025 1.27-.189.215-.378.243-.702.081-.324-.162-1.368-.504-2.605-1.607-.962-.857-1.612-1.917-1.801-2.241-.189-.324-.02-.499.142-.66.146-.146.324-.378.486-.567.162-.189.216-.324.324-.54.108-.216.054-.405-.027-.567-.081-.162-.73-1.755-1-2.403-.263-.633-.532-.547-.73-.557-.189-.009-.405-.011-.621-.011-.216 0-.567.081-.864.405-.297.324-1.134 1.107-1.134 2.7 0 1.593 1.161 3.13 1.323 3.346.162.216 2.286 3.49 5.537 4.894.774.334 1.378.534 1.85.683.777.247 1.484.212 2.043.128.623-.093 1.917-.783 2.187-1.539.27-.756.27-1.404.189-1.539-.081-.135-.297-.216-.621-.378Z"
    ></path>
  </svg>
  <span class="wa-float__pulse" aria-hidden="true"></span>
</a>

<style>
  .wa-float {
    position: fixed;
    right: 20px;
    right: max(20px, env(safe-area-inset-right));
    bottom: 20px;
    bottom: max(20px, env(safe-area-inset-bottom));
    width: 60px;
    height: 60px;
    min-width: 44px;
    min-height: 44px;
    border-radius: 999px;
    background: var(--whatsapp);
    color: var(--white);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 28px rgba(37, 211, 102, 0.45);
    z-index: 60;
    transition: transform 0.2s var(--ease-out-expo), box-shadow 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .wa-float:hover,
  .wa-float:focus-visible {
    transform: scale(1.07);
    box-shadow: 0 12px 32px rgba(37, 211, 102, 0.55);
  }

  .wa-float__icon {
    width: 30px;
    height: 30px;
    display: block;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .wa-float__pulse {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.45);
    animation: wa-pulse 2.4s var(--ease-out-expo) infinite;
    pointer-events: none;
  }

  @keyframes wa-pulse {
    0% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.5); }
    70% { box-shadow: 0 0 0 16px rgba(37, 211, 102, 0); }
    100% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0); }
  }

  /* Hide on mobile/tablet — drawer has WhatsApp CTA */
  @media (max-width: 1023px) {
    .wa-float {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wa-float,
    .wa-float__pulse {
      transition: none;
      animation: none;
    }
  }
</style>
