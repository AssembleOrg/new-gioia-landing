---
const reasons = [
  {
    icon: "shield",
    title: "Traslado seguro",
    desc: "Embalaje profesional, mantas acolchadas y sujeción para que tus muebles lleguen intactos.",
  },
  {
    icon: "clock",
    title: "Puntualidad",
    desc: "Si decimos a las 9 estamos a las 9. Tu tiempo importa tanto como tus pertenencias.",
  },
  {
    icon: "users",
    title: "Equipo con experiencia",
    desc: "Personal capacitado para mover desde un piano hasta una oficina entera sin contratiempos.",
  },
  {
    icon: "bubble",
    title: "Asesoría sin cargo",
    desc: "Te visitamos o coordinamos por video llamada para cotizar con precisión, sin compromiso.",
  },
];
---

<section class="why section">
  <div class="container">
    <header class="why__head">
      <span class="eyebrow">Por qué Gioia e Hijos</span>
      <h2>Una empresa familiar con la espalda de una operadora.</h2>
      <p class="why__intro">
        Somos una SRL con flota propia, depósito habilitado y un equipo que se mueve todos los días
        por el AMBA. Cuidamos cada mudanza como si fuera la nuestra.
      </p>
    </header>

    <div class="why__grid">
      {
        reasons.map((r) => (
          <article class="reason">
            <div class="reason__icon" aria-hidden="true">
              {r.icon === "shield" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 2 4 5v6c0 5 3.5 9.5 8 11 4.5-1.5 8-6 8-11V5l-8-3z" stroke-linejoin="round" />
                  <path d="m9 12 2 2 4-4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
              {r.icon === "clock" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="9" />
                  <path d="M12 7v5l3 2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
              {r.icon === "users" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M16 11a4 4 0 1 0-4-4" stroke-linecap="round" />
                  <circle cx="9" cy="7" r="4" />
                  <path d="M2 21v-1a6 6 0 0 1 6-6h2a6 6 0 0 1 6 6v1M22 21v-1a6 6 0 0 0-4-5.66" stroke-linecap="round" />
                </svg>
              )}
              {r.icon === "bubble" && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 11.5A8.5 8.5 0 1 1 12.5 3c4.694 0 8.5 3.806 8.5 8.5z" />
                  <path d="M8 17l-4 3v-3" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
            </div>
            <h3>{r.title}</h3>
            <p>{r.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .why {
    background: var(--white);
  }

  .why__head {
    max-width: 760px;
    margin-bottom: 56px;
  }

  .why__intro {
    color: var(--gris-700);
    font-size: 1.05rem;
  }

  .why__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 32px;
  }

  .reason {
    padding: 0;
  }

  .reason__icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--bordo) 0%, var(--bordo-dark) 100%);
    color: var(--white);
    display: grid;
    place-items: center;
    margin-bottom: 18px;
    box-shadow: 0 8px 18px rgba(122, 31, 44, 0.25);
  }

  .reason__icon svg {
    width: 28px;
    height: 28px;
  }

  .reason h3 {
    color: var(--ink);
    font-size: 1.4rem;
    margin-bottom: 8px;
  }

  .reason p {
    color: var(--gris-700);
    font-size: 0.95rem;
    margin: 0;
  }
</style>
